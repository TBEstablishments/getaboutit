<button class="ui-btn replay" id="replay">&#8635; REPLAY INTRO</button>

<script>
const sky=document.getElementById('sky');
for(let i=0;i<48;i++){const s=document.createElement('div');s.className='star'+(Math.random()>.6?' tw':'');
  s.style.left=Math.random()*100+'%';s.style.top=Math.random()*72+'%';s.style.animationDelay=Math.random()*5+'s';
  const sc=Math.random()*1.5+.5;s.style.transform='scale('+sc+')';sky.appendChild(s);}

let actx=null, muted=false;
function ac(){ if(!actx){try{actx=new (window.AudioContext||window.webkitAudioContext)();}catch(e){}}
  if(actx&&actx.state==='suspended')actx.resume(); return actx; }
function tone(freq,dur,type,vol,when){
  const a=ac(); if(!a)return; const t=a.currentTime+(when||0);
  const o=a.createOscillator(),g=a.createGain();
  o.type=type||'square'; o.frequency.setValueAtTime(freq,t);
  o.connect(g); g.connect(a.destination);
  g.gain.setValueAtTime(0.0001,t);
  g.gain.exponentialRampToValueAtTime(muted?0.0001:(vol||0.12),t+0.008);
  g.gain.exponentialRampToValueAtTime(0.0001,t+dur);
  o.start(t); o.stop(t+dur+0.03);
}
const S={
  tap(){tone(880,0.06,'square',0.10);},
  tick(){tone(1320,0.03,'square',0.05);},
  pick(){tone(660,0.07,'square',0.11);tone(990,0.09,'square',0.09,0.02);},
  coin(){tone(988,0.05,'square',0.12);tone(1319,0.10,'square',0.11,0.05);},
  win(){tone(523,0.10,'square',0.12);tone(659,0.10,'square',0.12,0.10);tone(784,0.18,'square',0.12,0.20);},
  rise(){const a=ac(); if(!a)return; const t=a.currentTime;
    const o=a.createOscillator(),g=a.createGain();
    o.type='sawtooth'; o.frequency.setValueAtTime(220,t);
    o.frequency.exponentialRampToValueAtTime(880,t+0.5);
    g.gain.setValueAtTime(0.0001,t);
    g.gain.exponentialRampToValueAtTime(muted?0.0001:0.16,t+0.06);
    g.gain.exponentialRampToValueAtTime(0.0001,t+0.6);
    o.connect(g); g.connect(a.destination); o.start(t); o.stop(t+0.65);
    tone(330,0.5,'square',0.05);
    const o2=a.createOscillator(),g2=a.createGain();
    o2.type='sine'; o2.frequency.value=64;
    g2.gain.setValueAtTime(0.0001,t);
    g2.gain.exponentialRampToValueAtTime(muted?0.0001:0.05,t+0.4);
    g2.gain.exponentialRampToValueAtTime(0.0001,t+1.8);
    o2.connect(g2); g2.connect(a.destination); o2.start(t); o2.stop(t+1.9);
  }
};
const soundBtn=document.getElementById('sound'), soundIcon=document.getElementById('soundIcon');
soundBtn.onclick=(e)=>{e.stopPropagation(); muted=!muted;
  soundBtn.lastChild.textContent=muted?' SOUND OFF':' SOUND ON';
  soundIcon.innerHTML=muted
    ?'<path d="M2 5h2l3-2.5v8L4 8H2z" fill="currentColor"/><line x1="8.5" y1="4.5" x2="12.5" y2="8.5" stroke="currentColor" stroke-width="1.1"/><line x1="12.5" y1="4.5" x2="8.5" y2="8.5" stroke="currentColor" stroke-width="1.1"/>'
    :'<path d="M2 5h2l3-2.5v8L4 8H2z" fill="currentColor"/><path d="M9 4.5q1.4 2 0 4" fill="none" stroke="currentColor" stroke-width="1.1"/><path d="M10.6 3q2.4 3.5 0 7" fill="none" stroke="currentColor" stroke-width="1.1"/>';
  if(!muted)S.tap();
};

const body=document.body,hero=document.getElementById('hero'),today=document.querySelector('.today');
function reveal(){
  if(!body.classList.contains('revealed')){
    body.classList.add('revealed'); S.coin(); setTimeout(()=>S.rise(),140);
    setTimeout(()=>today.scrollIntoView({behavior:'smooth'}),520);
  }else{today.scrollIntoView({behavior:'smooth'});}
}
hero.addEventListener('click',e=>{if(e.target.closest('.ui-btn'))return;reveal();});

const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')}),{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

document.querySelectorAll('.tab').forEach(t=>t.onclick=()=>{
  S.tap(); document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));t.classList.add('active');
  const f=t.dataset.f;
  document.querySelectorAll('.toy-wrap').forEach(w=>w.classList.toggle('hide',f!=='all'&&w.dataset.cat!==f));
});
document.getElementById('search').addEventListener('input',e=>{
  const q=e.target.value.toLowerCase().trim();
  document.querySelectorAll('.toy-wrap').forEach(w=>{
    const name=w.querySelector('.toy-name').textContent.toLowerCase();
    w.classList.toggle('hide',q&&!name.includes(q));});
});
document.addEventListener('keydown',e=>{if(e.key==='/'&&document.activeElement.tagName!=='INPUT'){e.preventDefault();document.getElementById('search').focus();}});

document.querySelectorAll('.toy-wrap').forEach(w=>{
  const toy=w.querySelector('.toy');
  w.addEventListener('mouseenter',()=>S.tick());
  toy.addEventListener('click',()=>{S.pick();toy.classList.add('press');setTimeout(()=>toy.classList.remove('press'),140);});
});
document.querySelectorAll('.daily').forEach(d=>d.addEventListener('click',()=>S.pick()));

document.getElementById('surprise').onclick=()=>{
  S.win();
  const toys=[...document.querySelectorAll('.toy-wrap:not(.hide)')];
  const pick=toys[Math.floor(Math.random()*toys.length)];
  pick.scrollIntoView({behavior:'smooth',block:'center'});
  const t=pick.querySelector('.toy');t.style.transform='translateY(-16px) scale(1.06)';
  t.style.boxShadow='0 0 36px var(--acc)';
  setTimeout(()=>{t.style.transform='';t.style.boxShadow='';},900);
};

document.getElementById('replay').onclick=(e)=>{e.stopPropagation();location.reload();};

const kc=['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];let kp=0;
document.addEventListener('keydown',e=>{
  kp=(e.key.toLowerCase()===kc[kp]||e.key===kc[kp])?kp+1:0;
  if(kp===kc.length){kp=0;coinStorm();}
});
function coinStorm(){
  S.win();
  for(let i=0;i<18;i++){setTimeout(()=>{
    const c=document.createElement('div');c.className='coin-rain';
    c.style.left=Math.random()*100+'vw';document.body.appendChild(c);
    const dur=1200+Math.random()*900;
    c.animate([{transform:'translateY(0) rotate(0)'},{transform:'translateY(105vh) rotate(540deg)'}],{duration:dur,easing:'cubic-bezier(.4,0,.7,1)'});
    setTimeout(()=>c.remove(),dur);
  },i*70);}
}

const reduce=matchMedia('(prefers-reduced-motion:reduce)').matches;

(function(){
  const cv=document.getElementById('snakeCanvas'),x=cv.getContext('2d'),N=8,C=15;
  let sn=[{x:3,y:4},{x:2,y:4},{x:1,y:4}],dir={x:1,y:0},food={x:6,y:2},MAX=10;
  function empty(){let p;do{p={x:(Math.random()*N)|0,y:(Math.random()*N)|0};}while(sn.some(s=>s.x===p.x&&s.y===p.y));return p;}
  function choose(){const opts=[{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}];let best=dir,bd=1e9;
    for(const o of opts){if(o.x===-dir.x&&o.y===-dir.y)continue;
      const nx=(sn[0].x+o.x+N)%N,ny=(sn[0].y+o.y+N)%N;
      if(sn.some(s=>s.x===nx&&s.y===ny))continue;
      const d=Math.abs(nx-food.x)+Math.abs(ny-food.y);if(d<bd){bd=d;best=o;}}dir=best;}
  function draw(){
    x.fillStyle='#06070f';x.fillRect(0,0,120,120);
    x.fillStyle='#ef233c';x.fillRect(food.x*C+3,food.y*C+3,C-6,C-6);
    sn.forEach((s,i)=>{x.fillStyle=i===0?'#06ffa5':'#0bd690';x.fillRect(s.x*C+1,s.y*C+1,C-2,C-2);});
  }
  function step(){choose();const h={x:(sn[0].x+dir.x+N)%N,y:(sn[0].y+dir.y+N)%N};
    sn.unshift(h);if(h.x===food.x&&h.y===food.y){food=empty();if(sn.length>MAX)sn.pop();}else sn.pop();draw();}
  draw(); if(!reduce)setInterval(step,270);
})();

(function(){
  const cv=document.getElementById('pongCanvas'),x=cv.getContext('2d');
  let ball={x:60,y:60,vx:2.1,vy:1.5},p1=50,p2=50;
  function draw(){
    x.fillStyle='#06070f';x.fillRect(0,0,120,120);
    x.fillStyle='rgba(255,255,255,.18)';for(let i=8;i<120;i+=16)x.fillRect(59,i,2,8);
    x.fillStyle='#fff';x.fillRect(8,p1-15,5,30);x.fillRect(107,p2-15,5,30);
    x.fillStyle='#00f5ff';x.fillRect(ball.x-3,ball.y-3,6,6);
  }
  function loop(){
    ball.x+=ball.vx;ball.y+=ball.vy;
    if(ball.y<6||ball.y>114)ball.vy*=-1;
    p1+=Math.max(-1.7,Math.min(1.7,(ball.y-p1)*0.5));
    p2+=Math.max(-1.7,Math.min(1.7,(ball.y-p2)*0.5));
    if(ball.x<15&&Math.abs(ball.y-p1)<17&&ball.vx<0)ball.vx=Math.abs(ball.vx);
    if(ball.x>105&&Math.abs(ball.y-p2)<17&&ball.vx>0)ball.vx=-Math.abs(ball.vx);
    if(ball.x<-2||ball.x>122){ball.x=60;ball.y=60;ball.vx=(Math.random()>.5?1:-1)*2.1;ball.vy=(Math.random()*2-1)*1.7;}
    draw();requestAnimationFrame(loop);
  }
  draw(); if(!reduce)loop();
})();

(function(){
  const cv=document.getElementById('runnerCanvas'),x=cv.getContext('2d'),G=92;
  let y=0,vy=0,onG=true,obs=[],sp=18,t=0,speed=2.4;
  function draw(){
    x.fillStyle='#06070f';x.fillRect(0,0,120,120);
    x.fillStyle='rgba(255,255,255,.25)';x.fillRect(0,G+14,120,2);
    const ry=G+y, f=(t>>3)&1;
    x.fillStyle='#ff9500';
    x.fillRect(30,ry-18,8,8);
    x.fillRect(28,ry-10,10,10);
    x.fillRect(24,ry-8,4,3);
    x.fillStyle='#e07e00';
    x.fillRect(28,ry,3,4+(f?0:-1));
    x.fillRect(34,ry,3,4+(f?-1:0));
    x.fillStyle='#3a0ca3';
    obs.forEach(o=>x.fillRect(o.x,G+4,8,10));
  }
  function loop(){
    t++; vy+=0.9; y+=vy; if(y>=0){y=0;vy=0;onG=true;}
    if(--sp<=0){obs.push({x:120});sp=58+Math.random()*42;}
    obs.forEach(o=>o.x-=speed); obs=obs.filter(o=>o.x>-12);
    const near=obs.find(o=>o.x>26&&o.x<52); if(near&&onG){vy=-11;onG=false;}
    draw();requestAnimationFrame(loop);
  }
  draw(); if(!reduce)loop();
})();
</script>
