<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>GETABOUTIT</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<style>
  :root{
    --pink:#ff006e;--magenta:#d100d1;--purple:#8338ec;--dpurple:#3a0ca3;
    --blue:#4361ee;--cyan:#00f5ff;--teal:#06ffa5;--yellow:#ffd60a;
    --orange:#ff9500;--red:#ef233c;--bg:#0a0a1e;--white:#fff;
    --arcade:'Press Start 2P','Courier New',monospace;
    --body:ui-monospace,'SFMono-Regular',Menlo,Consolas,monospace;
    --warm:rgba(255,149,0,.30);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--white);font-family:var(--body);overflow-x:hidden;position:relative}

  .sky{position:fixed;inset:0;z-index:0;pointer-events:none}
  .star{position:absolute;width:2px;height:2px;background:#fff;border-radius:1px;opacity:.5}
  .star.tw{animation:tw 5s ease-in-out infinite}
  @keyframes tw{0%,100%{opacity:.16}50%{opacity:.8}}
  .scanlines{position:fixed;inset:0;z-index:95;pointer-events:none;mix-blend-mode:overlay;
    background:repeating-linear-gradient(to bottom,rgba(255,255,255,.04) 0 1px,transparent 1px 3px)}
  .vignette{position:fixed;inset:0;z-index:96;pointer-events:none;
    background:radial-gradient(ellipse at center,transparent 54%,rgba(0,0,0,.5) 100%)}
  .wrap{position:relative;z-index:2}

  .hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
    text-align:center;padding:40px 16px 0;position:relative;overflow:hidden}
  .hero-bloom{position:absolute;left:50%;bottom:-26vh;transform:translateX(-50%);
    width:155vw;height:92vh;pointer-events:none;filter:blur(8px);
    background:radial-gradient(ellipse at center,var(--warm) 0%,rgba(255,0,110,.16) 32%,rgba(58,12,163,.10) 56%,transparent 72%);
    animation:rise 1.6s ease .5s both}
  .crt-line{position:absolute;left:8%;right:8%;top:50%;height:3px;background:#fff;
    box-shadow:0 0 30px 4px rgba(255,255,255,.8);border-radius:2px;transform:scaleX(0);opacity:0;
    animation:crt 1s ease both}
  @keyframes crt{0%{transform:scaleX(0);opacity:0}14%{transform:scaleX(1);opacity:1}
    60%{transform:scaleX(1) scaleY(1);opacity:1}100%{transform:scaleX(1) scaleY(40);opacity:0}}

  .wordmark{font-family:var(--arcade);font-size:clamp(1.4rem,8vw,5.5rem);line-height:1;letter-spacing:0;
    color:var(--white);white-space:nowrap;max-width:100%;
    animation:glitchIn 1s steps(1) .55s both,breathe 8s ease-in-out 1.6s infinite}
  @keyframes breathe{0%,100%{text-shadow:3px 0 var(--pink),-3px 0 var(--cyan)}
    50%{text-shadow:5px 0 var(--pink),-5px 0 var(--cyan);filter:brightness(1.04)}}
  @keyframes glitchIn{
    0%{opacity:0;text-shadow:18px 0 var(--pink),-18px 0 var(--cyan)}
    20%{opacity:1;text-shadow:-14px 0 var(--pink),12px 0 var(--cyan);transform:translateX(6px)}
    40%{text-shadow:10px 0 var(--pink),-10px 0 var(--cyan);transform:translateX(-4px)}
    60%{text-shadow:-6px 0 var(--pink),6px 0 var(--cyan);transform:translateX(2px)}
    80%{text-shadow:4px 0 var(--pink),-4px 0 var(--cyan)}
    100%{opacity:1;text-shadow:3px 0 var(--pink),-3px 0 var(--cyan);transform:translateX(0)}}

  .tagline{font-family:var(--arcade);font-size:clamp(.46rem,1.7vw,.66rem);letter-spacing:.28em;
    color:rgba(255,255,255,.5);margin-top:26px;animation:fadeUp .5s ease 1.5s both}
  .cta{font-family:var(--arcade);font-size:clamp(.6rem,2vw,.82rem);letter-spacing:.14em;color:var(--yellow);
    margin-top:38px;padding:17px 30px;border:2px solid var(--yellow);border-radius:4px;cursor:pointer;
    background:transparent;text-transform:uppercase;transition:all .25s;
    animation:fadeUp .5s ease 1.7s both,coinPulse 1.3s ease-in-out 2.4s infinite}
  .cta:hover{background:rgba(255,214,10,.12)}
  @keyframes coinPulse{0%,100%{box-shadow:0 0 0 rgba(255,214,10,0);transform:scale(1)}
    50%{box-shadow:0 0 26px rgba(255,214,10,.45);transform:scale(1.03)}}
  .coin{position:absolute;left:50%;top:62%;width:14px;height:14px;border-radius:50%;background:var(--yellow);
    box-shadow:0 0 10px var(--yellow);opacity:0;transform:translateX(-50%)}
  body.revealed .coin{animation:coinDrop .6s ease both}
  body.revealed .hero-bloom{animation:surge 1s ease both}
  @keyframes coinDrop{0%{opacity:1;top:55%}100%{opacity:0;top:80%}}
  @keyframes surge{0%{opacity:1}30%{opacity:1;filter:blur(8px) brightness(1.55)}100%{opacity:1;filter:blur(8px) brightness(1)}}

  .horizon{position:absolute;left:0;right:0;bottom:88px;height:1px;
    background:linear-gradient(to right,transparent,var(--orange),var(--pink),var(--orange),transparent);
    box-shadow:0 0 24px 2px rgba(255,149,0,.35);animation:fadeUp .8s ease 1.3s both}
  .scroll-hint{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);font-family:var(--arcade);
    font-size:.48rem;letter-spacing:.26em;color:rgba(255,255,255,.4);
    animation:fadeUp .6s ease 2.6s both,bob 2.4s ease-in-out 3.2s infinite}
  @keyframes bob{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,5px)}}

  @keyframes rise{0%{opacity:.1}100%{opacity:1}}
  @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

  .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s cubic-bezier(.2,.7,.2,1)}
  .reveal.in{opacity:1;transform:none}

  .today{position:relative;max-width:1080px;margin:0 auto;padding:90px 20px 30px}
  .today::before{content:'';position:absolute;left:0;right:0;top:0;height:280px;z-index:-1;
    background:radial-gradient(ellipse at 50% 0%,rgba(255,149,0,.10),transparent 60%)}
  .today-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px}
  .today-eyebrow{font-family:var(--arcade);font-size:.6rem;letter-spacing:.3em;color:var(--orange)}
  .streak{font-family:var(--arcade);font-size:.54rem;letter-spacing:.12em;color:var(--yellow);display:flex;align-items:center;gap:8px}
  .flame{display:inline-block;width:14px;height:18px}
  .daily-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  @media(max-width:640px){.daily-row{grid-template-columns:1fr}}
  .daily{position:relative;border:1px solid rgba(255,149,0,.3);border-radius:8px;padding:18px 18px 16px;
    background:linear-gradient(160deg,rgba(255,149,0,.06),rgba(10,10,30,.2));cursor:pointer;
    transition:transform .25s cubic-bezier(.2,.7,.2,1),box-shadow .25s,border-color .25s}
  .daily:hover{transform:translateY(-4px);box-shadow:0 14px 30px rgba(0,0,0,.4);border-color:rgba(255,149,0,.6)}
  .daily-cat{font-family:var(--arcade);font-size:.46rem;letter-spacing:.2em;color:var(--cyan);margin-bottom:10px}
  .daily-name{font-family:var(--arcade);font-size:.84rem;letter-spacing:.04em;color:var(--white);margin-bottom:7px}
  .daily-desc{font-family:var(--body);font-size:.8rem;color:rgba(255,255,255,.5)}

  .floor{max-width:1080px;margin:0 auto;padding:70px 20px 40px}
  .floor-eyebrow{font-family:var(--arcade);font-size:.6rem;letter-spacing:.3em;color:var(--cyan);margin-bottom:12px}
  .floor-title{font-family:var(--arcade);font-size:clamp(1rem,4vw,1.7rem);letter-spacing:.04em;margin-bottom:10px;
    text-shadow:2px 0 var(--pink),-2px 0 var(--cyan)}
  .floor-sub{font-family:var(--body);font-size:.92rem;line-height:1.7;color:rgba(255,255,255,.5);max-width:420px;margin-bottom:34px}

  .controls-row{display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap}
  .search{flex:1;min-width:200px;display:flex;align-items:center;gap:10px;padding:14px 16px;
    border:1px solid rgba(255,255,255,.18);border-radius:6px;background:rgba(255,255,255,.02)}
  .search input{flex:1;background:transparent;border:none;outline:none;color:var(--white);
    font-family:var(--arcade);font-size:.54rem;letter-spacing:.08em}
  .search input::placeholder{color:rgba(255,255,255,.32)}
  .surprise{font-family:var(--arcade);font-size:.54rem;letter-spacing:.1em;color:var(--pink);
    padding:0 20px;border:2px solid var(--pink);border-radius:6px;background:transparent;cursor:pointer;
    display:flex;align-items:center;gap:9px;transition:all .2s;white-space:nowrap}
  .surprise:hover{background:rgba(255,0,110,.12);box-shadow:0 0 20px rgba(255,0,110,.3)}
  .die{width:16px;height:16px;display:inline-block}

  .tabs{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:50px}
  .tab{font-family:var(--arcade);font-size:.56rem;letter-spacing:.1em;padding:13px 16px;
    border:1px solid rgba(255,255,255,.18);border-radius:4px;color:rgba(255,255,255,.55);cursor:pointer;
    background:transparent;transition:all .18s}
  .tab.active{color:var(--white);border-color:var(--cyan);box-shadow:0 0 14px rgba(0,245,255,.25);border-bottom:2px solid var(--cyan)}
  .tab:hover{color:var(--white)}

  .shelf{display:grid;grid-template-columns:repeat(4,1fr);gap:48px 36px}
  @media(max-width:900px){.shelf{grid-template-columns:repeat(3,1fr);gap:42px 26px}}
  @media(max-width:560px){.shelf{grid-template-columns:repeat(2,1fr);gap:38px 20px}}

  .toy-wrap{display:flex;flex-direction:column;align-items:center;transition:opacity .3s,transform .3s}
  .toy-wrap.hide{display:none}
  .toy{position:relative;width:100%;aspect-ratio:1;border-radius:14px;display:flex;align-items:center;justify-content:center;
    cursor:pointer;overflow:hidden;transition:transform .3s cubic-bezier(.2,.7,.2,1),box-shadow .3s}
  .toy::before{content:'';position:absolute;inset:0;border-radius:14px;z-index:1;
    background:linear-gradient(160deg,rgba(255,255,255,.22),transparent 42%,rgba(0,0,0,.28))}
  .toy::after{content:'';position:absolute;inset:0;border-radius:14px;z-index:3;pointer-events:none;
    background:repeating-linear-gradient(to bottom,rgba(0,0,0,.10) 0 1px,transparent 1px 3px);opacity:.5}
  .toy svg,.toy canvas{position:relative;z-index:2;width:58%;height:58%;image-rendering:pixelated}
  .toy.live{align-items:stretch;justify-content:stretch}
  .toy.live canvas{position:absolute;inset:0;width:100%;height:100%;z-index:2}
  .live-badge{position:absolute;top:7px;right:8px;z-index:4;font-family:var(--arcade);font-size:.34rem;
    letter-spacing:.12em;color:var(--bg);background:rgba(255,255,255,.85);padding:2px 4px;border-radius:2px}
  .pedestal{position:relative;width:100%;height:28px;margin-top:6px}
  .pedestal::before{content:'';position:absolute;left:10%;right:10%;top:6px;height:2px;
    background:linear-gradient(to right,transparent,rgba(255,255,255,.18),transparent)}
  .pedestal::after{content:'';position:absolute;left:50%;top:0;transform:translateX(-50%);width:78%;height:24px;border-radius:50%;
    background:radial-gradient(ellipse at center,rgba(255,149,0,.3),transparent 70%);transition:all .3s}
  .toy-wrap:hover .toy{transform:translateY(-12px);box-shadow:0 18px 40px rgba(0,0,0,.5),0 0 30px -4px var(--acc)}
  .toy-wrap:hover .pedestal::after{width:92%;height:30px;background:radial-gradient(ellipse at center,rgba(255,149,0,.5),transparent 72%)}
  .toy.press{transform:translateY(-4px) scale(.97)!important}
  .toy-name{font-family:var(--arcade);font-size:.6rem;letter-spacing:.05em;margin-top:14px;text-align:center}
  .toy-desc{font-family:var(--body);font-size:.74rem;color:rgba(255,255,255,.45);margin-top:5px;text-align:center}

  .a-teal{--acc:#06ffa5;background:linear-gradient(150deg,#0bd690,#06ffa5)}
  .a-orange{--acc:#ff9500;background:linear-gradient(150deg,#e07e00,#ff9500)}
  .a-blue{--acc:#4361ee;background:linear-gradient(150deg,#2f49c9,#4361ee)}
  .a-white{--acc:#fff;background:linear-gradient(150deg,#c7c7d6,#fff)}
  .a-yellow{--acc:#ffd60a;background:linear-gradient(150deg,#e0b800,#ffd60a)}
  .a-pink{--acc:#ff006e;background:linear-gradient(150deg,#cc0058,#ff006e)}
  .a-purple{--acc:#8338ec;background:linear-gradient(150deg,#5f28b0,#8338ec)}
  .a-red{--acc:#ef233c;background:linear-gradient(150deg,#b81a2e,#ef233c)}
  .a-cyan{--acc:#00f5ff;background:linear-gradient(150deg,#0bb6c9,#00f5ff)}
  .a-dark{--acc:#06ffa5;background:linear-gradient(160deg,#0d0d24,#05050f)}

  .footer{position:relative;text-align:center;padding:90px 20px 70px;margin-top:50px}
  .footer::before{content:'';position:absolute;left:0;right:0;bottom:0;height:300px;z-index:-1;
    background:radial-gradient(ellipse at 50% 100%,rgba(255,149,0,.12),transparent 65%)}
  .creed{font-family:var(--arcade);font-size:.56rem;line-height:2.3;letter-spacing:.12em;color:rgba(255,255,255,.5)}
  .creed b{color:var(--white)}
  .foot-line{font-family:var(--body);font-size:.9rem;color:rgba(255,255,255,.4);margin:22px 0 30px}
  .foot-wordmark{font-family:var(--arcade);font-size:1rem;letter-spacing:0;color:var(--white);
    text-shadow:2px 0 var(--pink),-2px 0 var(--cyan);animation:breathe 8s ease-in-out infinite}
  .foot-links{margin-top:22px;display:flex;gap:22px;justify-content:center;flex-wrap:wrap}
  .foot-links a{font-family:var(--arcade);font-size:.48rem;letter-spacing:.12em;color:rgba(255,255,255,.4);text-decoration:none;transition:color .2s}
  .foot-links a:hover{color:var(--cyan)}

  .ui-btn{position:fixed;z-index:120;font-family:var(--arcade);font-size:.46rem;letter-spacing:.1em;
    color:rgba(255,255,255,.45);background:rgba(8,8,20,.7);border:1px solid rgba(255,255,255,.15);
    border-radius:20px;padding:8px 12px;cursor:pointer;backdrop-filter:blur(6px);transition:all .2s;
    display:flex;align-items:center;gap:7px}
  .ui-btn:hover{color:var(--yellow);border-color:rgba(255,214,10,.4)}
  .sound{right:14px;top:14px}
  .replay{right:14px;bottom:14px}

  .coin-rain{position:fixed;top:-20px;width:12px;height:12px;border-radius:50%;background:var(--yellow);
    box-shadow:0 0 8px var(--yellow);z-index:130;pointer-events:none}

  @media(prefers-reduced-motion:reduce){*{animation:none!important}.wordmark{opacity:1}.reveal{opacity:1;transform:none}}
</style>
</head>
<body class="cozy">

<div class="sky" id="sky"></div>
<div class="scanlines"></div>
<div class="vignette"></div>

<button class="ui-btn sound" id="sound"><svg id="soundIcon" width="13" height="13" viewBox="0 0 13 13"><path d="M2 5h2l3-2.5v8L4 8H2z" fill="currentColor"/><path d="M9 4.5q1.4 2 0 4" fill="none" stroke="currentColor" stroke-width="1.1"/><path d="M10.6 3q2.4 3.5 0 7" fill="none" stroke="currentColor" stroke-width="1.1"/></svg> SOUND ON</button>

<div class="wrap">
  <section class="hero" id="hero">
    <div class="hero-bloom"></div>
    <div class="crt-line"></div>
    <h1 class="wordmark">GETABOUTIT</h1>
    <p class="tagline">16 GAMES &middot; NO QUARTERS &middot; NO CLOCK</p>
    <button class="cta" id="cta">&#9656; PRESS START</button>
    <div class="coin"></div>
    <div class="horizon"></div>
    <div class="scroll-hint">&#9660; THE FLOOR</div>
  </section>

  <section class="today reveal">
    <div class="today-head">
      <span class="today-eyebrow">&#9656; TODAY</span>
      <span class="streak">
        <svg class="flame" viewBox="0 0 14 18"><rect x="6" y="0" width="2" height="2" fill="#ffd60a"/><rect x="5" y="2" width="4" height="3" fill="#ffd60a"/><rect x="4" y="5" width="6" height="3" fill="#ff9500"/><rect x="3" y="8" width="8" height="4" fill="#ffd60a"/><rect x="2" y="12" width="10" height="4" fill="#ef233c"/><rect x="4" y="12" width="6" height="3" fill="#ff9500"/><rect x="3" y="16" width="8" height="2" fill="#ef233c"/></svg>
        2 DAY STREAK
      </span>
    </div>
    <div class="daily-row">
      <div class="daily"><div class="daily-cat">ARCADE</div><div class="daily-name">SNAKE</div><div class="daily-desc">beat 24 today</div></div>
      <div class="daily"><div class="daily-cat">BOARD</div><div class="daily-name">CHESS</div><div class="daily-desc">today's opening</div></div>
      <div class="daily"><div class="daily-cat">CARDS</div><div class="daily-name">BLACKJACK</div><div class="daily-desc">five hands, one seed</div></div>
    </div>
  </section>

  <section class="floor reveal">
    <div class="floor-eyebrow">&#9656; THE FLOOR</div>
    <h2 class="floor-title">CHOOSE YOUR GAME</h2>
    <p class="floor-sub">sixteen machines. one quarter. no closing time.</p>

    <div class="controls-row">
      <div class="search">
        <svg width="14" height="14" viewBox="0 0 14 14"><circle cx="6" cy="6" r="4.2" fill="none" stroke="rgba(255,255,255,.4)" stroke-width="1.4"/><line x1="9.2" y1="9.2" x2="12.5" y2="12.5" stroke="rgba(255,255,255,.4)" stroke-width="1.4"/></svg>
        <input placeholder="SEARCH (PRESS /)" id="search">
      </div>
      <button class="surprise" id="surprise">
        <svg class="die" viewBox="0 0 16 16"><rect x="1" y="1" width="14" height="14" rx="3" fill="none" stroke="#ff006e" stroke-width="1.4"/><circle cx="5" cy="5" r="1.3" fill="#ff006e"/><circle cx="11" cy="5" r="1.3" fill="#ff006e"/><circle cx="8" cy="8" r="1.3" fill="#ff006e"/><circle cx="5" cy="11" r="1.3" fill="#ff006e"/><circle cx="11" cy="11" r="1.3" fill="#ff006e"/></svg>
        SURPRISE ME
      </button>
    </div>

    <div class="tabs">
      <button class="tab active" data-f="all">ALL</button>
      <button class="tab" data-f="arcade">ARCADE</button>
      <button class="tab" data-f="board">BOARD</button>
      <button class="tab" data-f="cards">CARDS</button>
    </div>

    <div class="shelf" id="shelf">
      <div class="toy-wrap" data-cat="arcade"><div class="toy a-purple"><svg viewBox="0 0 24 24"><rect x="7" y="13" width="11" height="3" fill="#fff" opacity=".9"/><rect x="6" y="9.5" width="11" height="3" fill="#3a0ca3"/><rect x="8" y="6" width="11" height="3" fill="#ff006e"/></svg></div><div class="pedestal"></div><div class="toy-name">STACK</div><div class="toy-desc">build it high</div></div>

      <div class="toy-wrap" data-cat="arcade"><div class="toy live a-dark"><span class="live-badge">LIVE</span><canvas id="snakeCanvas" width="120" height="120"></canvas></div><div class="pedestal"></div><div class="toy-name">SNAKE</div><div class="toy-desc">eat. grow. don't bite.</div></div>

      <div class="toy-wrap" data-cat="arcade"><div class="toy a-cyan"><svg viewBox="0 0 24 24"><rect x="7" y="9" width="10" height="3.2" fill="#063a4d"/><rect x="10.4" y="12.2" width="3.2" height="3.2" fill="#063a4d"/></svg></div><div class="pedestal"></div><div class="toy-name">BLOCKS</div><div class="toy-desc">clear the lines</div></div>

      <div class="toy-wrap" data-cat="arcade"><div class="toy a-orange"><svg viewBox="0 0 24 24"><text x="12" y="15.5" font-family="'Press Start 2P',monospace" font-size="5" fill="#5a2d00" text-anchor="middle" font-weight="700">2048</text></svg></div><div class="pedestal"></div><div class="toy-name">2048</div><div class="toy-desc">merge to win</div></div>

      <div class="toy-wrap" data-cat="arcade"><div class="toy a-pink"><svg viewBox="0 0 24 24"><rect x="5" y="6" width="4" height="2.2" fill="#fff"/><rect x="10" y="6" width="4" height="2.2" fill="#ffd60a"/><rect x="15" y="6" width="4" height="2.2" fill="#06ffa5"/><rect x="5" y="9" width="4" height="2.2" fill="#00f5ff"/><rect x="10" y="9" width="4" height="2.2" fill="#fff"/><rect x="15" y="9" width="4" height="2.2" fill="#ffd60a"/><circle cx="12" cy="17" r="1.6" fill="#fff"/></svg></div><div class="pedestal"></div><div class="toy-name">BREAKOUT</div><div class="toy-desc">break the wall</div></div>

      <div class="toy-wrap" data-cat="arcade"><div class="toy live a-dark"><span class="live-badge">LIVE</span><canvas id="pongCanvas" width="120" height="120"></canvas></div><div class="pedestal"></div><div class="toy-name">PONG</div><div class="toy-desc">first to eleven</div></div>

      <div class="toy-wrap" data-cat="arcade"><div class="toy a-yellow"><svg viewBox="0 0 24 24"><rect x="7" y="10" width="7" height="5" fill="#5a4800"/><rect x="6" y="11.5" width="1.5" height="2.5" fill="#5a4800"/><rect x="14" y="11" width="3" height="1.5" fill="#ff9500"/><rect x="9" y="8.5" width="3" height="1.5" fill="#5a4800"/><rect x="12.5" y="11.5" width="1.6" height="1.6" fill="#0a0a1e"/></svg></div><div class="pedestal"></div><div class="toy-name">FLAP</div><div class="toy-desc">mind the gap</div></div>

